# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/gameplatform?retryWrites=true&w=majority

# JWT Secret — make this a long random string (e.g. use: openssl rand -base64 32)
JWT_SECRET=your_super_secret_jwt_key_here

# Port the server runs on
PORT=5000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
